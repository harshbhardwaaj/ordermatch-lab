# Copy to .env for local development. Never commit the real .env.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local Postgres (see README for setup). Render provides its own
# DATABASE_URL automatically when this is deployed as a Blueprint.
DATABASE_URL=postgres://ordermatch:ordermatch_dev_pw@localhost:5432/ordermatch_dev

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Backend-only. Never expose this to frontend code or the browser.
OPENAI_API_KEY=
